DATABASE_URL=mysql+pymysql://user:pass@host:3306/openwork

JWT_SECRET=CHANGE_ME
ACCESS_TTL_MIN=60
REFRESH_TTL_DAYS=7

WORKSPACE_ROOT=/var/lib/openwork/workspaces
DATA_DIR=/var/lib/openwork

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

SANDBOX_ENABLED=true
SANDBOX_TIME_LIMIT_SEC=120
SANDBOX_MAX_OUTPUT_BYTES=100000

DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=us
DAYTONA_SNAPSHOT=
DAYTONA_AUTO_STOP_INTERVAL_MIN=0
DAYTONA_AUTO_ARCHIVE_INTERVAL_DAYS=0
DAYTONA_AUTO_DELETE_INTERVAL_DAYS=-1
