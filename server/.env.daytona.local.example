# Openwork backend -> local Daytona (self-hosted on this machine)
# Fill this key after you create it in local Daytona Dashboard.
DAYTONA_API_KEY=replace_with_local_daytona_api_key

# If Openwork server runs on host machine:
DAYTONA_API_URL=http://localhost:3000/api

# If Openwork server runs inside devcontainer, use host.docker.internal instead:
# DAYTONA_API_URL=http://host.docker.internal:3000/api

# Default region id in official local Daytona compose.
DAYTONA_TARGET=us
