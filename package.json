{
  "name": "openwork",
  "private": true,
  "version": "0.1.0",
  "description": "Browser-server workspace for deep agents",
  "author": "LangChain",
  "license": "MIT",
  "homepage": "https://github.com/langchain-ai/openwork",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/langchain-ai/openwork.git"
  },
  "bugs": {
    "url": "https://github.com/langchain-ai/openwork/issues"
  },
  "scripts": {
    "dev:web": "npm --prefix web run dev",
    "build:web": "npm --prefix web run build",
    "preview:web": "npm --prefix web run preview",
    "dev:server": "cd server && uv run uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "test:server": "cd server && uv run python -m unittest",
    "build": "npm run build:web",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.7.4"
  }
}
